# Database
TG_DATABASE_URL=postgresql://thundergate:thundergate@localhost:5432/thundergate

# Proxy
TG_PROXY_PORT=3001
TG_PROXY_HOST=0.0.0.0
TG_MAX_PAYLOAD_SIZE=1048576
TG_DEFAULT_RATE_LIMIT=100

# Dashboard
TG_DASHBOARD_PORT=3000
TG_NEXTAUTH_SECRET=change-me-to-a-random-32-char-string
TG_NEXTAUTH_URL=http://localhost:3000

# NextAuth (required — NextAuth reads these directly from process.env)
NEXTAUTH_SECRET=change-me-to-a-random-32-char-string
NEXTAUTH_URL=http://localhost:3000

# HITL
TG_HITL_TIER1_TIMEOUT_MS=300000
TG_HITL_TIER2_TIMEOUT_MS=900000

# Logging
TG_LOG_LEVEL=debug
