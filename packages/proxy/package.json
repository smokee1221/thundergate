{
  "name": "@thundergate/proxy",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Fastify reverse proxy with agent auth, rate limiting, and HITL connection holding",
  "author": "Dimitar Ruskov",
  "license": "MIT",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "@fastify/rate-limit": "^10.2.0",
    "@thundergate/db": "workspace:*",
    "@thundergate/engine": "workspace:*",
    "drizzle-orm": "^0.36.0",
    "fastify": "^5.2.0",
    "fastify-plugin": "^5.1.0",
    "pino": "^9.6.0",
    "postgres": "^3.4.0",
    "undici": "^7.3.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^25.2.3",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
