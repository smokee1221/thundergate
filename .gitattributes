# Auto detect text files and perform LF normalization
* text=auto

# Force LF for source files
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.mjs text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.css text eol=lf
*.html text eol=lf
*.sh text eol=lf

# Binary files
*.png binary
*.ico binary
*.jpg binary
*.jpeg binary
*.gif binary
*.woff binary
*.woff2 binary

# Vendor files (excluded from GitHub language stats)
pnpm-lock.yaml linguist-generated
